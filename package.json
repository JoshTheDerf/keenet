{
  "name": "keenet",
  "version": "1.0.0",
  "description": "KeeNet — free cross-platform password manager compatible with KeePass (Vue 3 rebuild, based on KeeWeb)",
  "type": "module",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "gen:icons": "node scripts/gen-icons.mjs",
    "predev": "node scripts/gen-icons.mjs",
    "prebuild": "node scripts/gen-icons.mjs",
    "build": "vue-tsc --noEmit && vite build",
    "build:web": "vue-tsc --noEmit && vite build --base /app/ --outDir dist/app && cp landing.html dist/index.html && cp -r public/* dist/app/",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint .",
    "audit": "npm audit --omit=dev",
    "tauri": "tauri",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "cap:sync": "npm run build && cap sync",
    "cap:android": "npm run build && cap sync android && cap open android",
    "cap:ios": "npm run build && cap sync ios && cap open ios",
    "cap:add:android": "cap add android",
    "cap:add:ios": "cap add ios"
  },
  "engines": {
    "node": ">=20.20.2"
  },
  "dependencies": {
    "@capacitor/app": "8.1.0",
    "@capacitor/browser": "8.0.3",
    "@capacitor/clipboard": "8.0.1",
    "@capacitor/core": "8.4.1",
    "@capacitor/filesystem": "8.1.2",
    "@capacitor/haptics": "8.0.2",
    "@capacitor/preferences": "8.0.1",
    "@capacitor/status-bar": "8.0.2",
    "@nuxt/ui": "4.9.0",
    "@tauri-apps/api": "2.11.1",
    "@vueuse/core": "14.3.0",
    "capacitor-native-biometric": "4.2.2",
    "dompurify": "3.4.11",
    "hash-wasm": "4.12.0",
    "kdbxweb": "2.1.1",
    "marked": "15.0.12",
    "pinia": "3.0.4",
    "vue": "3.5.39",
    "vue-router": "4.6.4",
    "zxcvbn": "4.4.2"
  },
  "devDependencies": {
    "@capacitor/android": "8.4.1",
    "@capacitor/assets": "3.0.5",
    "@capacitor/cli": "8.4.1",
    "@capacitor/ios": "8.4.1",
    "@eslint/js": "10.0.1",
    "@iconify-json/lucide": "1.2.116",
    "@tailwindcss/vite": "4.3.2",
    "@tauri-apps/cli": "2.11.4",
    "@types/node": "22.20.1",
    "@types/zxcvbn": "4.4.5",
    "@vitejs/plugin-vue": "5.2.4",
    "@vue/test-utils": "2.4.11",
    "eslint": "10.6.0",
    "eslint-plugin-vue": "10.9.2",
    "globals": "17.7.0",
    "happy-dom": "15.11.7",
    "jsdom": "29.1.1",
    "tailwindcss": "4.3.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vite": "6.4.3",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.10",
    "vue-eslint-parser": "10.4.1",
    "vue-tsc": "3.3.7"
  }
}
